# =============================================
# AI SaaS Backend - Environment Variables
# =============================================

# Server Configuration
NODE_ENV=development
PORT=5000

# ─── MongoDB Atlas ────────────────────────────────────────────────────────────
# Paste your Atlas connection string here:
# Format: mongodb+srv://<user>:<password>@cluster0.xxxxx.mongodb.net/<dbname>?retryWrites=true&w=majority
MONGODB_URI=mongodb+srv://<user>:<pass>@cluster0.xxxxx.mongodb.net/ai_saas

# ─── JWT ─────────────────────────────────────────────────────────────────────
JWT_SECRET=your_secret_key_here
JWT_EXPIRES_IN=7d

# ─── Groq AI ─────────────────────────────────────────────────────────────────
# Get your key at: https://console.groq.com/keys
GROQ_API_KEY=gsk_your_key_here

# Available Groq models (pick one):
#   llama-3.3-70b-versatile   ← Best quality (recommended)
#   llama-3.1-8b-instant      ← Fastest / lowest latency
#   mixtral-8x7b-32768        ← Large context window
#   gemma2-9b-it              ← Google Gemma 2
GROQ_MODEL=llama-3.3-70b-versatile
GROQ_MAX_TOKENS=2048

# ─── CORS ─────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed frontend origins
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173

# ─── Rate Limiting ───────────────────────────────────────────────────────────
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100
AI_RATE_LIMIT_MAX=20
