GROQ_API_KEY=gsk_your_key_here

# ─── FRONTEND CONFIG ───────────────────────────────────────────────────────────
# Point this to your backend container IP/DNS if deploying to a VPS
REACT_APP_API_URL=http://localhost:5000/api


# ─── MongoDB Atlas ────────────────────────────────────────────────────────────
MONGODB_URI=mongodb+srv://<user>:<pass>@cluster0.xxxxx.mongodb.net/ai_saas

# ─── JWT ─────────────────────────────────────────────────────────────────────
JWT_SECRET=your_secret_key_here

# ─── Groq AI ─────────────────────────────────────────────────────────────────
